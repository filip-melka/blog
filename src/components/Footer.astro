---
const tools = [
	{
		name: 'Astro',
		url: 'https://astro.build/'
	},
	{
		name: 'Tailwind',
		url: 'https://tailwindcss.com/'
	},
	{
		name: 'Solid',
		url: 'https://www.solidjs.com/'
	},
	{
		name: 'Svelte',
		url: 'https://svelte.dev/'
	},
	{
		name: 'Supabase',
		url: 'https://supabase.com/'
	}
]
---

<footer class="flex h-20 items-center justify-center px-4 opacity-70 sm:px-20">
	<p class="text-center text-xs sm:text-sm">
		Made with {
			tools.map((tool, index) => (
				<>
					<a class="inline-block underline" href={tool.url}>
						{tool.name}
					</a>
					{index < tools.length - 1 && <span>, </span>}
				</>
			))
		}.
	</p>
</footer>
