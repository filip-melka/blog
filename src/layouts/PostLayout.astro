---
import { Image } from 'astro:assets'
import BaseLayout from './BaseLayout.astro'
import { Icon } from 'astro-icon/components'
import '../styles/markdown.css'
import Claps from '../components/solid/Claps'

const { frontmatter } = Astro.props
---

<BaseLayout pageTitle={frontmatter.title} includeLatex={true}>
	<main class="px-4 sm:px-12 md:px-20">
		<article class="mx-auto max-w-[1200px] pb-12">
			<figure class="mx-auto w-full pb-10 lg:w-10/12 xl:w-9/12">
				<Image class="w-full" src={frontmatter.banner.image} alt={frontmatter.banner.alt} />
			</figure>
			<div class="relative">
				<div class="absolute top-0 left-0 hidden h-full w-20 lg:block">
					<aside class="sticky top-20">
						<Claps client:idle slug={frontmatter.slug} />
					</aside>
				</div>
				<div class="mx-auto max-w-[650px]">
					<h1>{frontmatter.title}</h1>
					<slot />
					<div class="border-text/10 mt-12 block border-t pt-8 lg:hidden">
						<Claps client:idle slug={frontmatter.slug} />
					</div>
				</div>
				<div class="absolute top-0 right-0 hidden h-full w-20 lg:block">
					<div class="h-full"></div>
					<a href="#" class="cursor-pointe sticky bottom-20 z-10 block w-fit">
						<Icon
							class="scale-110 text-4xl transition-transform duration-300 hover:scale-150"
							name="flowbite:angle-up-outline"
						/>
					</a>
				</div>
			</div>
		</article>
	</main>
</BaseLayout>
